model Connection {
  id        String   @id @default(uuid())
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id])
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id])
  macAddress String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("connections")
}
