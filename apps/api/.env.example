DATABASE_URL=postgresql://postgres:password@localhost:5433/client_manager

# Evolution API (docker-compose service evolution-api on :8080)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=evolution-local-dev-key

# Optional dev override for payment-received WhatsApp (production: use Account.phone)
# PAYMENT_NOTIFY_PHONE=5535999516263

# Meta WhatsApp Cloud API (Tech Provider / Embedded Signup)
# META_APP_ID=
# META_APP_SECRET=
# META_EMBEDDED_SIGNUP_CONFIG_ID=
# META_GRAPH_API_VERSION=v22.0
# META_WEBHOOK_VERIFY_TOKEN=

# Billing automation scheduler (node-cron in-process)
# BILLING_SCHEDULER_ENABLED=false
# BILLING_SCHEDULER_TZ=America/Sao_Paulo
# Interval in minutes. Default: 10 in development, 60 (hourly at :00) in production.
# Values below 60 run all active tenants on each tick (ignores configured hour — useful for testing).
# BILLING_SCHEDULER_INTERVAL_MINUTES=10
# Optional full cron override (takes precedence over INTERVAL_MINUTES):
# BILLING_SCHEDULER_CRON=*/10 * * * *
# Force hour matching on/off when using CRON override (auto: true only for "0 * * * *"):
# BILLING_SCHEDULER_MATCH_HOUR=false
